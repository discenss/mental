# bot/.env.prod — переменные бота в проде (скопируй в bot/.env.prod).
BOT_TOKEN=123456:AA...                       # токен бота от @BotFather
API_BASE_URL=http://backend:8000             # ВНУТРИ docker-сети — имя сервиса backend
OPENAI_API_KEY=sk-...                        # для распознавания голоса (Whisper)
WHISPER_MODEL=whisper-1
TESTER_IDS=<твой_telegram_id>                 # кому доступен тест-режим ("*" = всем)

# ── webhook (прод) ──
USE_WEBHOOK=true
WEBHOOK_BASE=https://mental.rhythmos.online   # публичный домен mental
WEBHOOK_PATH=/tg/webhook
WEBHOOK_SECRET=CHANGE_ME_random_secret        # произвольная строка; сверяется с Telegram
WEBHOOK_PORT=8011
