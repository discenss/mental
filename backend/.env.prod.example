# backend/.env.prod — переменные бэкенда в проде (скопируй в backend/.env.prod).
# DATABASE_URL и CONTENT_DIR задаются через docker-compose (не дублируй здесь).
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...            # ключ OpenAI (та же, что локально)
# ANTHROPIC_API_KEY=...          # если LLM_PROVIDER=anthropic
